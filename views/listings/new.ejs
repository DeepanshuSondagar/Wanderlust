<% layout("layouts/boilerplate") -%>
 
<div class="row">
    <div class="col-8 offset-2" >
        <br>
<h3>Creating a New Listings</h3>
    <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
        <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input name="listing[title]" 
            placeholder="Add catchy  title" type="text" class="form-control" required>
                     <div class="invalid-feedback">title is good </div>

        </div>

        <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea name="listing[description]" placeholder="enter description" class="form-control" required></textarea>
        <div class="invalid-feedback">Description  is not  good </div>

       </div>
       
       

       <div class="mb-3">
        <label for="image" class="form-label">Upload Listing Image</label>
        <input name="listing[image]"   type="file" class="form-control" required>
        
       </div>
        
       <div class="mb-3">
              <label for="location" class="form-label">Location</label>
           <input name="listing[location]" placeholder="Jaipur, Rajisthan" type="text" class="form-control" required>
            <div class="invalid-feedback">Location is not good </div>
       </div>
       

       <div class="row">
            <div class="mb-3 col-md-4">
                <label for="price" class="form-label">Price</label>
                <input name="listing[price]" placeholder="12000" type="number" step="0.01" class="form-control" required>
            <div class="invalid-feedback">Price is not good </div>
            </div>
       
      <div class="mb-3 col-md-6">
        <label for="country" class="form-label">Country</label>
        <input name="listing[country]" placeholder="India" type="text" class="form-control" required>
     <div class="invalid-feedback">Country is not good </div>  
    </div>
       </div>
       
       <br><br>
       
       
       <button class="btn btn-dark add-btn">Add </button>
    </form>
    
    <br>
    </div>
 </div>

 