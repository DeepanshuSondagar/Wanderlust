<% layout("layouts/boilerplate") %>

<div class="row mt-3">
    <div class="alert alert-danger col-6 offset-3" role="alert">
      <h4>Error</h4>
      <p class="mb-0"><%= message || 'Something went wrong' %></p>
      <% if (typeof statusCode !== 'undefined') { %>
        <small class="text-muted">Status: <%= statusCode %></small>
      <% } %>
  </div>
</div>